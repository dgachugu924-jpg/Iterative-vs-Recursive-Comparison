xd    public static void main(String[] args) {
        int number = 10;

        long iterativeResult = factorialIterative(number);
        long recursiveResult = factorialRecursive(number);

        System.out.println("Iterative Result: " + iterativeResult);
        System.out.println("Recursive Result: " + recursiveResult);

        // Performance comparison
        long startIter = System.nanoTime();
        factorialIterative(number);
        long endIter = System.nanoTime();

        long startRec = System.nanoTime();
        factorialRecursive(number);
        long endRec = System.nanoTime();

        System.out.println("Iterative Time: " + (endIter - startIter) + " ns");
        System.out.println("Recursive Time: " + (endRec - startRec) + " ns");
    }
}
